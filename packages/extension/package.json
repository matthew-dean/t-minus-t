{
  "name": "typescript-minus-typescript",
  "displayName": "TypeScript Minus TypeScript",
  "description": "Write TypeScript syntax in .js files, stored as JavaScript with JSDoc comments",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "TypeScript Minus TypeScript",
      "properties": {
        "tMinusTS.autoGenerateDts": {
          "type": "boolean",
          "default": false,
          "description": "Automatically generate .d.ts files when saving .js files"
        }
      }
    },
    "customEditors": [
      {
        "viewType": "tMinusTS.typescriptEditor",
        "displayName": "TypeScript Editor",
        "selector": [
          {
            "filenamePattern": "*.js"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build",
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "ts-jsdoc-sync": "workspace:*",
    "typescript": "^5.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@10.0.0"
}

